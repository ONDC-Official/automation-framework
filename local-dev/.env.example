# =============================================================================
# ONDC Automation Workbench — Local Development Environment
# =============================================================================
# Copy this file to .env and adjust as needed.
# All values shown are safe defaults; nothing here is a real credential.

# ── Common ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# Pin a specific image tag for the docker-compose.images.yml variant
# (default: latest). Use this when reproducing a known-good combination.
# WORKBENCH_IMAGE_TAG=v0.1.0

# ── Infrastructure ───────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_HOST=redis

# Yugabyte (used by db-service)
DB_URL=jdbc:yugabytedb://yugabyte:5433/yugabyte
DB_USER=yugabyte
DB_PASSWORD=yugabyte

# ── Service ports (host bindings) ────────────────────────────────────────────
UI_FRONTEND_PORT=3000
CONFIG_SERVICE_PORT=3001
DB_SERVICE_PORT=8080
FORM_SERVICE_PORT=3003
RECORDER_SERVICE_PORT=3004
REPORT_SERVICE_PORT=3006
UI_BACKEND_PORT=3007
MOCK_PLAYGROUND_PORT=3010

# Backoffice (admin UI — only started with `--profile backoffice`)
BACKOFFICE_BACKEND_PORT=5200
BACKOFFICE_FRONTEND_PORT=5100

# Beckn-onix (only started with `--profile onix`)
BECKN_ONIX_PORT=8081

# ── Service URLs (inter-service, inside the workbench network) ───────────────
CONFIG_SERVICE_URL=http://config-service:3001
DB_SERVICE_URL=http://db-service:8080
FORM_SERVICE_URL=http://form-service:3003
RECORDER_SERVICE_URL=http://recorder-service:3004
REPORT_SERVICE_URL=http://report-service:3006
UI_BACKEND_URL=http://ui-backend:3007
MOCK_PLAYGROUND_URL=http://mock-playground:3010

# ── Spec / registry endpoints ────────────────────────────────────────────────
# Default points at ONDC's public dev environment. Override for self-hosting.
SPEC_REGISTRY_URL=https://dev-automation.ondc.org/api-service
GATEWAY_URL=https://staging.gateway.ondc.org
REGISTRY_URL=https://staging.registry.ondc.org/v2.0

# ── API keys (local dev only) ────────────────────────────────────────────────
DB_SERVICE_API_KEY=dev-api-key
JWT_SECRET=dev-jwt-secret-change-me
