# Runtime env vars for domain API services (ondc-onix-*).
# Shared across all domain builds — generated by scripts/build-api-service.sh.
#
# SECRETS: replace every *_change_me placeholder with real values before running.

# Service identity
PORT=7039
HOSTED_ENV=LOCAL
NODE_ENV=development
SUBSCRIBER_ID=local.workbench
SERVICE_NAME=automation-api-service-local

# Internal service URLs (docker network)
CONFIG_SERVICE_URL=http://config-service:5556
DATA_BASE_URL=http://db-service:5001
MOCK_SERVER_URL=http://playground-mock-service:3000
RECORDER_SERVICE_HTTP_URL=http://recorder-service:8090
RECORDER_SERVICE_GRPC_URL=recorder-service:8089

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
TRACE_URL=http://jaeger:4318/v1/traces

# Secrets — fill in before running
API_SERVICE_KEY=local_api_service_key_change_me
ENCR_PRIVATE=your_encryption_private_key_change_me
SIGNING_PRIVATE=your_signing_private_key_change_me
SIGN_PRIVATE_KEY=your_sign_private_key_change_me
NO_TOKEN=
