# Shared non-URL values — consistent key names used as-is across all services.
# Service URLs live in root .env and are translated per-service in docker-compose.yml.

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
HOSTED_ENV=LOCAL

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_ADDR=redis:6379

# ── MongoDB (services declare their own MONGO_URI with db path) ───────────────
DB_HOST=mongo
DB_PORT=27017
DB_USERNAME=
DB_PASSWORD=

# ── Observability ─────────────────────────────────────────────────────────────
TRACE_URL=http://jaeger:4318/v1/traces
LOKI_HOST=

# ── Local identity ────────────────────────────────────────────────────────────
SUBSCRIBER_ID=dev-automation.ondc.org
WORKBENCH_SUBSCRIBER_ID=dev-automation.ondc.org
PRAMAAN_ENVIRONMENT=local
RECORDER_ENV=local
ONDC_ENV=

# ── External URLs (no local equivalent) ───────────────────────────────────────
VALIDATION_URL=https://log-validation.ondc.org/api/validate
analyticsAPI=https://pramaan.ondc.org/beta/analytics-api
CARE_URL=https://ondc-uat-api.kellton.net/api/plan/grievance
FIS_TUNNEL_URL=https://gateway-preprod.ondc.org
NO_URL=https://analytics-api-staging.aws.ondc.org/
