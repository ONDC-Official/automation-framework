# Canonical internal service URLs — one source of truth per service.
# Referenced as ${VAR} in docker-compose.yml for alias translation.
# These are NOT loaded into containers directly; only the mapped keys
# in each service's environment: block reach the container.

MOCK_SVC=http://playground-mock-service:3000/mock
DB_SVC=http://db-service:5001
CONFIG_SVC=http://config-service:5556
# API_SVC=http://api-service:80/api-service
API_SVC=http://host.docker.internal:3032/api-service
REPORT_SVC=http://report-service:3000
UI_BACKEND_SVC=http://ui-backend:5000
REGISTRY_SVC=http://registry-service:8080/v2.0/
PRAMAAN_BUYER_SVC=http://report-pramaan-buyer:3005
PRAMAAN_SELLER_SVC=http://report-pramaan-seller:3005
USER_MGMT_SVC=http://automation-user-management:8082
RECORDER_HTTP_SVC=http://recorder-service:8090
RECORDER_GRPC_SVC=recorder-service:8089

# ── Shared auth key ───────────────────────────────────────────────────────────
# Single key used across all inter-service authentication.
# Alias names: API_SERVICE_KEY, PW_LOGS_API_KEY, AUTOMATION_DB_API_KEY,
#              RECORDER_DB_API_KEY, DB_SERVICE_API_KEY, DB_KEY
API_SVC_KEY=local_api_service_key_change_me